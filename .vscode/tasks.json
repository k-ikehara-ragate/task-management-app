{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: Nuxt 起動",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {}
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "nuxt",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Nuxt",
          "endsPattern": "Local:.*localhost"
        }
      },
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Cursorでアプリを表示 (Simple Browser)",
      "type": "shell",
      "command": "open 'vscode://vscode.simple-browser/show?url=http://localhost:3000'",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "silent" },
      "dependsOn": []
    }
  ]
}
